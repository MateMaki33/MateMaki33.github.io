---
import traumaData from "../collections/trauma.json";
import pedData from "../collections/trauma_pediatrico.json";
import IndiceShocKComponent from "./calculators/IndiceShocKComponent.vue";
import TraumaScoreComponent from "./calculators/TraumaScoreComponent.vue";
import IndiceTraumaPediatricoComponent from "./calculators/IndiceTraumaPediatricoComponent.vue";
import SuperficieQuemadaPediatricaComponent from "./calculators/SuperficieQuemadaPediatricaComponent.vue";
import CodigoPptComponent from "./calculators/CodigoPptComponent.vue";
import PrealertaAtmisterComponent from "./calculators/PrealertaAtmisterComponent.vue";
import CriteriosGravedadQuemadurasComponent from "./calculators/CriteriosGravedadQuemadurasComponent.vue";
const activacion = traumaData.codigo_trauma.criterios_activacion;
const hospitales = traumaData.codigo_trauma.hospitales_activacion;
const valoracion = traumaData.valoracion_primaria;
const ped = pedData.trauma_pediatrico;
const chuleta = ped.chuleta_farmacos;
---

<div class="container">
  <header class="page-head">
    <span class="eyebrow">Madrid 112 · CAM</span>
    <h1>Código Trauma</h1>
    <div class="page-divider"></div>
  </header>

  <!-- ═══ ACTIVACIÓN Y DESTINO ═══ -->
  <section class="section">
    <div class="section-head">
      <span class="eyebrow">Activación</span>
      <h2>Código &amp; destino</h2>
    </div>
    <div class="btn-grid">
      <button onclick="modal_activacion.showModal()" class="btn">Criterios de Activación</button>
      <button onclick="modal_hospitales.showModal()" class="btn">Hospitales</button>
      <button onclick="modal_paciente.showModal()" class="btn">Paciente / Incidente</button>
    </div>
  </section>

  <!-- ═══ VALORACIÓN PRIMARIA ═══ -->
  <section class="section">
    <div class="section-head">
      <span class="eyebrow">Valoración primaria</span>
      <h2>Exploración ABCDE</h2>
    </div>
    <div class="btn-grid">
      <button onclick="modal_respiratorio.showModal()" class="btn">Respiratorio</button>
      <button onclick="modal_circulatorio.showModal()" class="btn">Circulatorio</button>
      <button onclick="modal_neuro.showModal()" class="btn">Neurológico</button>
      <button onclick="modal_lesiones.showModal()" class="btn">Lesiones</button>
      <button onclick="modal_farmacos.showModal()" class="btn">Fármacos y Vías</button>
      <button onclick="modal_protocolos.showModal()" class="btn">Protocolos / Escalas</button>
    </div>
  </section>

  <!-- ═══ ESCALAS ═══ -->
  <section class="section">
    <div class="section-head">
      <span class="eyebrow">Escalas</span>
      <h2>Calculadoras de gravedad</h2>
    </div>
    <div class="btn-grid">
      <IndiceShocKComponent client:load></IndiceShocKComponent>
      <TraumaScoreComponent client:load></TraumaScoreComponent>
    </div>
  </section>

  <!-- ═══ TRAUMA PEDIÁTRICO ═══ -->
  <section class="section panel ped-panel">
    <div class="section-head">
      <span class="eyebrow">
        <span class="ped-badge">PED</span> Población pediátrica
      </span>
      <h2>Trauma pediátrico</h2>
      <p class="section-note">{ped.intro}</p>
    </div>

    <div class="ped-block">
      <h3 class="ped-block-title">Activación &amp; transferencia</h3>
      <div class="btn-grid">
        <CodigoPptComponent client:load />
        <PrealertaAtmisterComponent client:load />
        <button class="btn" onclick="modal_ped_constantes.showModal()">Constantes Vitales</button>
        <button class="btn" onclick="modal_ped_sri.showModal()">SRI · Intubación</button>
        <CriteriosGravedadQuemadurasComponent client:load label="Gravedad Quemaduras" />
      </div>
    </div>

    <div class="ped-block">
      <h3 class="ped-block-title">Fármacos &amp; dosis</h3>
      <div class="btn-grid">
        <button class="btn btn-chuleta" onclick="modal_ped_chuleta.showModal()">💉 Chuleta de Fármacos</button>
      </div>
    </div>

    <div class="ped-block">
      <h3 class="ped-block-title">Escalas pediátricas</h3>
      <div class="btn-grid">
        <IndiceTraumaPediatricoComponent client:load />
        <SuperficieQuemadaPediatricaComponent client:load />
      </div>
    </div>
  </section>

</div>

<!-- ═══ Modales Trauma Pediátrico ═══ -->
<dialog id="modal_ped_constantes">
  <h2>{ped.constantes.titulo}</h2>
  <div class="table-wrap">
    <table class="ped-table">
      <thead>
        <tr>{ped.constantes.cabeceras.map((c) => <th>{c}</th>)}</tr>
      </thead>
      <tbody>
        {ped.constantes.filas.map((fila) => (
          <tr>
            {fila.map((cell, i) => (
              <td class={i === 0 ? "col-head" : ""}>{cell}</td>
            ))}
          </tr>
        ))}
      </tbody>
    </table>
  </div>
  <p class="nota">{ped.constantes.nota}</p>
  <form method="dialog"><button class="btn">Cerrar</button></form>
</dialog>

<dialog id="modal_ped_sri">
  <h2>{ped.sri.titulo}</h2>
  <h3>Sedantes</h3>
  <div class="table-wrap">
    <table class="ped-table">
      <thead>
        <tr><th>Fármaco</th><th>Dosis</th><th>Observaciones</th></tr>
      </thead>
      <tbody>
        {ped.sri.sedantes.map((s) => (
          <tr>
            <td class="col-head">{s.farmaco}</td>
            <td class="col-dose">{s.dosis}</td>
            <td>{s.obs}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
  <h3>Paralizantes musculares</h3>
  <div class="table-wrap">
    <table class="ped-table">
      <thead>
        <tr><th>Fármaco</th><th>Dosis</th><th>Observaciones</th></tr>
      </thead>
      <tbody>
        {ped.sri.paralizantes.map((p) => (
          <tr>
            <td class="col-head">{p.farmaco}</td>
            <td class="col-dose">{p.dosis}</td>
            <td>{p.obs}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
  <form method="dialog"><button class="btn">Cerrar</button></form>
</dialog>

<dialog id="modal_ped_chuleta" class="chuleta-modal">
  <h2>{chuleta.titulo}</h2>
  <p class="nota">{chuleta.nota}</p>

  {chuleta.grupos.map((g) => (
    <div class="chuleta-grupo">
      <div class="chuleta-grupo-head">
        <h3>{g.titulo}</h3>
        {g.extra && <span class="chuleta-extra">{g.extra}</span>}
      </div>
      <div class="chuleta-cards">
        {g.farmacos.map((f) => (
          <div class="chuleta-card">
            <div class="cc-top">
              <span class="cc-name">{f.nombre}</span>
              <span class="cc-pres">{f.presentacion}</span>
            </div>
            <div class="cc-dose">{f.dosis}</div>
            {f.dilucion && (
              <div class="cc-row"><span class="cc-key">Dilución</span><span>{f.dilucion}</span></div>
            )}
            {f.uso && (
              <div class="cc-row"><span class="cc-key">Uso</span><span>{f.uso}</span></div>
            )}
            {f.truco && (
              <div class="cc-truco"><span class="cc-truco-tag">Truco</span>{f.truco}</div>
            )}
          </div>
        ))}
      </div>
    </div>
  ))}

  <form method="dialog" class="chuleta-foot"><button class="btn">Cerrar</button></form>
</dialog>

<style>
  /* Pediatric module — distinct amber-accented panel */
  .ped-panel {
    --accent: var(--neon-orange);
    gap: 1.5rem;
    border-color: rgba(245, 158, 11, 0.28);
    background:
      linear-gradient(180deg, rgba(245, 158, 11, 0.05), transparent 55%),
      var(--color-card-bg);
  }
  .ped-badge {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    color: #1a1206;
    background: var(--neon-orange);
    padding: 0.1rem 0.4rem;
    border-radius: 4px;
    margin-right: 0.35rem;
    box-shadow: 0 0 16px rgba(245, 158, 11, 0.4);
  }

  .ped-block {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  .ped-block-title {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(228, 239, 248, 0.5);
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(245, 158, 11, 0.15);
  }

  /* Tables */
  .table-wrap {
    width: 100%;
    overflow-x: auto;
    border: 1px solid rgba(45, 156, 219, 0.18);
    border-radius: 10px;
    margin-bottom: 0.5rem;
  }
  .ped-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.85rem;
    min-width: 460px;
  }
  .ped-table th {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-subtitle);
    text-align: left;
    padding: 0.6rem 0.8rem;
    background: rgba(45, 156, 219, 0.08);
    border-bottom: 1px solid rgba(45, 156, 219, 0.25);
    white-space: nowrap;
  }
  .ped-table td {
    padding: 0.55rem 0.8rem;
    border-bottom: 1px solid rgba(45, 156, 219, 0.08);
    color: rgba(228, 239, 248, 0.82);
    vertical-align: top;
    line-height: 1.4;
  }
  .ped-table tbody tr:last-child td { border-bottom: none; }
  .ped-table tbody tr:nth-child(even) td { background: rgba(45, 156, 219, 0.03); }
  .ped-table .col-head {
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--color-text);
    white-space: nowrap;
  }
  .ped-table .col-dose {
    font-family: var(--font-mono);
    color: var(--neon-glow);
    white-space: nowrap;
  }

  .nota {
    font-size: 0.82rem;
    color: rgba(228, 239, 248, 0.5);
    font-style: italic;
    margin: 0.5rem 0 1rem;
  }

  /* ── Botón chuleta ── */
  .btn-chuleta {
    border-color: rgba(245, 158, 11, 0.5);
    color: var(--neon-glow);
  }
  .btn-chuleta:hover {
    background: rgba(245, 158, 11, 0.16);
    border-color: var(--neon-orange);
    color: #fff;
  }

  /* ── Chuleta de fármacos (modal) ── */
  .chuleta-modal { max-width: min(95vw, 880px); }

  .chuleta-grupo { margin-bottom: 1.4rem; }
  .chuleta-grupo:last-of-type { margin-bottom: 0.5rem; }

  .chuleta-grupo-head {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex-wrap: wrap;
    padding-bottom: 0.45rem;
    margin-bottom: 0.7rem;
    border-bottom: 1px solid rgba(245, 158, 11, 0.18);
  }
  .chuleta-grupo-head h3 {
    margin: 0;
    color: var(--neon-glow);
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.04em;
  }
  .chuleta-extra {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: #fca5a5;
    background: rgba(239, 68, 68, 0.1);
    border: 1px solid rgba(239, 68, 68, 0.28);
    border-radius: 5px;
    padding: 0.14rem 0.5rem;
  }

  .chuleta-cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 0.65rem;
  }

  .chuleta-card {
    background: rgba(255, 255, 255, 0.025);
    border: 1px solid rgba(45, 156, 219, 0.16);
    border-radius: 10px;
    padding: 0.75rem 0.85rem;
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .cc-top { display: flex; flex-direction: column; gap: 0.1rem; }
  .cc-name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.02rem;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--color-text);
    line-height: 1.1;
  }
  .cc-pres {
    font-family: var(--font-mono);
    font-size: 0.71rem;
    color: rgba(228, 239, 248, 0.45);
  }

  .cc-dose {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--neon-glow);
    background: rgba(245, 158, 11, 0.08);
    border: 1px solid rgba(245, 158, 11, 0.22);
    border-radius: 6px;
    padding: 0.35rem 0.55rem;
    line-height: 1.4;
  }

  .cc-row {
    display: flex;
    gap: 0.5rem;
    font-size: 0.79rem;
    line-height: 1.45;
    color: rgba(228, 239, 248, 0.78);
  }
  .cc-key {
    flex-shrink: 0;
    font-family: var(--font-display);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(125, 180, 210, 0.55);
    min-width: 3.8rem;
    padding-top: 0.12rem;
  }

  .cc-truco {
    font-size: 0.79rem;
    line-height: 1.5;
    color: #fcd34d;
    background: rgba(245, 158, 11, 0.06);
    border-left: 2px solid var(--neon-orange);
    border-radius: 0 6px 6px 0;
    padding: 0.4rem 0.6rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    align-items: baseline;
  }
  .cc-truco-tag {
    font-family: var(--font-display);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #1a1206;
    background: var(--neon-orange);
    border-radius: 3px;
    padding: 0.08rem 0.4rem;
  }

  .chuleta-foot { margin-top: 1.5rem; display: flex; justify-content: center; }
</style>

<!-- Modales -->
<dialog id="modal_activacion">
  <h2>Criterios de Activación</h2>
  <div class="subsection">
    <h3>Signos Vitales</h3>
    <ul>
      {activacion.signos_vitales.map(s => <li><strong>{s.parametro}:</strong> {s.valor}</li>)}
    </ul>
  </div>
  <div class="subsection">
    <h3>Lesiones</h3>
    <ul>
      {activacion.lesiones.map(l => <li>{l}</li>)}
    </ul>
  </div>
  <div class="subsection">
    <h3>Mecanismos de Lesión</h3>
    <ul>
      {activacion.mecanismos_lesion.map(m => <li>{m}</li>)}
    </ul>
  </div>
  <div class="subsection">
    <h3>Factores de Riesgo</h3>
    <ul>
      {activacion.factores_riesgo.map(f => <li>{f}</li>)}
    </ul>
  </div>
  <form method="dialog"><button class="btn">Cerrar</button></form>
</dialog>

<dialog id="modal_hospitales">
  <h2>Hospitales</h2>
  <ul>{hospitales.map(h => <li>{h}</li>)}</ul>
  <form method="dialog"><button class="btn">Cerrar</button></form>
</dialog>

<dialog id="modal_paciente">
  <h2>Paciente / Incidente</h2>
  <ul>
    <li>{valoracion.paciente_incidente.edad}</li>
    <li>{valoracion.paciente_incidente.sexo}</li>
    {valoracion.paciente_incidente.tipo_incidente.map(t => <li>{t}</li>)}
  </ul>
  <form method="dialog"><button class="btn">Cerrar</button></form>
</dialog>

<dialog id="modal_respiratorio">
  <h2>Respiratorio</h2>
  <h3>Vía aérea</h3>
  <ul>{valoracion.via_aerea.map(v => <li>{v}</li>)}</ul>
  <h3>Ventilación</h3>
  <ul>{valoracion.ventilación.map(v => <li>{v}</li>)}</ul>
  <form method="dialog"><button class="btn">Cerrar</button></form>
</dialog>

<dialog id="modal_circulatorio">
  <h2>Circulatorio</h2>
  <ul>
    <li>{valoracion.circulatorio.constantes}</li>
    {valoracion.circulatorio.signos.map(s => <li>{s}</li>)}
  </ul>
  <form method="dialog"><button class="btn">Cerrar</button></form>
</dialog>

<dialog id="modal_neuro">
  <h2>Neurológico</h2>
  <ul>{valoracion.neurologico.map(n => <li>{n}</li>)}</ul>
  <form method="dialog"><button class="btn">Cerrar</button></form>
</dialog>

<dialog id="modal_lesiones">
  <h2>Lesiones</h2>
  <ul>
    <li>{valoracion.lesiones.localizacion}</li>
    <li><a href="/quemados">{valoracion.lesiones.quemados}</a></li>
    {valoracion.lesiones.tipo_lesion.map(t => <li>{t}</li>)}
  </ul>
  <form method="dialog"><button class="btn">Cerrar</button></form>
</dialog>

<dialog id="modal_farmacos">
  <h2>Fármacos y Vías</h2>
  <h3>Dispositivos</h3>
  <ul>{valoracion.farmacos_vias.dispositivos.map(d => <li>{d}</li>)}</ul>
  <h3>Vías</h3>
  <ul>{valoracion.farmacos_vias.vias.map(v => <li>{v}</li>)}</ul>
  <h3>Fármacos</h3>
  <ul>{valoracion.farmacos_vias.Farmacos.map(f => <li>{f}</li>)}</ul>
  <form method="dialog"><button class="btn">Cerrar</button></form>
</dialog>

<dialog id="modal_protocolos">
  <h2>Protocolos / Escalas</h2>
  <ul>
    {valoracion.protocolos_especificos.map(p => <li>{p}</li>)}
    <li>{valoracion.trauma_score}</li>
    <li>{valoracion.indice_shock}</li>
  </ul>
  <form method="dialog"><button class="btn">Cerrar</button></form>
</dialog>