---
import codigos from '../data/codigos';
import escalas from '../data/escalas';
---

<style>
  nav {
    background: rgba(5, 16, 30, 0.92);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(45, 156, 219, 0.18);
    box-shadow: 0 2px 24px rgba(0, 0, 0, 0.4), 0 1px 0 rgba(45, 156, 219, 0.08);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 1.5rem;
    height: var(--nav-height);
    position: sticky;
    top: 0;
    z-index: var(--z-nav);
  }

  /* ── Logo ── */
  .logo {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.35rem;
    color: var(--color-primary);
    text-shadow: 0 0 20px rgba(45, 156, 219, 0.5);
    text-decoration: none;
    user-select: none;
    flex-shrink: 0;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: text-shadow 0.2s ease;
  }

  .logo:hover {
    color: var(--color-primary);
    text-shadow: 0 0 30px rgba(45, 156, 219, 0.8);
  }

  /* ── Main list ── */
  .nav-list {
    list-style: none;
    display: flex;
    align-items: center;
    gap: 1.75rem;
    margin: 0;
    padding: 0;
  }

  /* Shared link / button style */
  .nav-list > li > a,
  .nav-btn {
    color: rgba(228, 239, 248, 0.75);
    text-decoration: none;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.92rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    position: relative;
    cursor: pointer;
    user-select: none;
    white-space: nowrap;
    /* reset button defaults */
    background: none;
    border: none;
    padding: 0;
    font-family: inherit;
    display: inline-flex;
    align-items: center;
    gap: 0.3em;
    transition: color 0.2s ease;
  }

  /* Underline animation */
  .nav-list > li > a::after,
  .nav-btn::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 100%;
    height: 1.5px;
    background: var(--color-primary);
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.25s ease;
  }

  .nav-list > li > a:hover,
  .nav-btn:hover,
  .dropdown.open > .nav-btn {
    color: var(--color-subtitle);
  }

  .nav-list > li > a:hover::after,
  .nav-btn:hover::after,
  .dropdown.open > .nav-btn::after {
    transform: scaleX(1);
    transform-origin: left;
  }

  /* ── Chevron ── */
  .chevron {
    font-style: normal;
    font-size: 0.65em;
    transition: transform 0.25s ease;
    display: inline-block;
    opacity: 0.7;
  }

  .dropdown.open .chevron {
    transform: rotate(180deg);
  }

  /* ── Dropdown ── */
  .dropdown {
    position: relative;
  }

  .submenu {
    display: none;
    position: absolute;
    top: calc(100% + 10px);
    left: 0;
    list-style: none;
    flex-direction: column;
    padding: 0.5rem 0;
    margin: 0;
    min-width: 180px;
    background: rgba(8, 20, 38, 0.97);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(45, 156, 219, 0.22);
    border-radius: 10px;
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.6), 0 0 0 1px rgba(45, 156, 219, 0.06);
    z-index: var(--z-dropdown);
  }

  .dropdown.open .submenu {
    display: flex;
    animation: dropIn 0.18s cubic-bezier(0.16, 1, 0.3, 1);
  }

  @keyframes dropIn {
    from { opacity: 0; transform: translateY(-6px) scale(0.98); }
    to   { opacity: 1; transform: translateY(0)  scale(1); }
  }

  .submenu li a {
    display: block;
    padding: 0.5rem 1.25rem;
    color: rgba(228, 239, 248, 0.7);
    text-decoration: none;
    font-family: var(--font-display);
    font-size: 0.88rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    white-space: nowrap;
    transition: color 0.15s ease, background 0.15s ease;
  }

  .submenu li a:hover {
    color: var(--color-subtitle);
    background: rgba(45, 156, 219, 0.1);
  }

  /* ── Hamburger button ── */
  .menu-btn {
    display: none;
    flex-direction: column;
    cursor: pointer;
    width: 28px;
    height: 20px;
    justify-content: space-between;
    border: none;
    background: none;
    padding: 0;
    flex-shrink: 0;
  }

  .menu-btn span {
    height: 2px;
    width: 100%;
    background: var(--color-primary);
    border-radius: 2px;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    display: block;
  }

  .menu-btn.is-open span:nth-child(1) { transform: rotate(45deg) translate(5px, 5px); }
  .menu-btn.is-open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .menu-btn.is-open span:nth-child(3) { transform: rotate(-45deg) translate(5px, -5px); }

  /* ── Mobile overlay ── */
  .nav-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(2, 11, 22, 0.65);
    z-index: var(--z-overlay);
    backdrop-filter: blur(4px);
  }

  .nav-overlay.is-open {
    display: block;
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .menu-btn {
      display: flex;
    }

    .nav-list {
      position: fixed;
      top: 0;
      right: 0;
      background: rgba(8, 20, 38, 0.98);
      backdrop-filter: blur(24px);
      height: 100dvh;
      width: min(280px, 82vw);
      flex-direction: column;
      align-items: flex-start;
      padding: calc(var(--nav-height) + 1.5rem) 0 2rem 1.5rem;
      gap: 0.5rem;
      transform: translateX(100%);
      transition: transform 0.32s cubic-bezier(0.16, 1, 0.3, 1);
      box-shadow: -8px 0 40px rgba(0, 0, 0, 0.5), -1px 0 0 rgba(45, 156, 219, 0.2);
      border-left: 1px solid rgba(45, 156, 219, 0.15);
      z-index: var(--z-nav);
      overflow-y: auto;
      box-sizing: border-box;
    }

    .nav-list.is-open {
      transform: translateX(0);
    }

    /* Submenus always expanded in sidebar */
    .submenu {
      display: flex;
      position: static;
      border: none;
      box-shadow: none;
      background: transparent;
      padding: 0.25rem 0 0.5rem 1rem;
      min-width: unset;
      animation: none;
      gap: 0;
      border-radius: 0;
    }

    .submenu li a {
      padding: 0.4rem 0.5rem;
      font-size: 0.85rem;
      color: rgba(228, 239, 248, 0.55);
    }

    .submenu li a:hover {
      color: var(--color-subtitle);
      background: transparent;
    }

    .nav-btn {
      font-size: 1.05rem;
    }

    .nav-list > li > a {
      font-size: 1.05rem;
    }

    /* Separator between nav items on mobile */
    .nav-list > li + li {
      border-top: 1px solid rgba(45, 156, 219, 0.1);
      padding-top: 0.65rem;
      width: calc(100% - 1.5rem);
    }

    /* Close button inside sidebar */
    .mobile-close-item {
      display: flex !important;
      border-top: none !important;
      padding-top: 0 !important;
      width: 100% !important;
      margin-bottom: 0.5rem;
    }

    .mobile-close-btn {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      background: none;
      border: 1px solid rgba(45, 156, 219, 0.25);
      border-radius: 8px;
      color: rgba(228, 239, 248, 0.65);
      font-family: var(--font-display);
      font-size: 0.88rem;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      padding: 0.55rem 1rem;
      cursor: pointer;
      width: calc(100% - 1.5rem);
      transition: color 0.2s ease, border-color 0.2s ease, background 0.2s ease;
    }

    .mobile-close-btn:hover {
      color: var(--color-subtitle);
      border-color: rgba(45, 156, 219, 0.5);
      background: rgba(45, 156, 219, 0.08);
    }

    .mobile-close-icon {
      font-size: 1.1rem;
      line-height: 1;
    }
  }

  .mobile-close-item {
    display: none;
  }
</style>

<nav>
  <a href="/" class="logo">MadRescue112</a>

  <button class="menu-btn" id="hamburger" aria-label="Abrir menú" aria-expanded="false" aria-controls="main-menu">
    <span></span>
    <span></span>
    <span></span>
  </button>

  <div class="nav-overlay" id="nav-overlay" aria-hidden="true"></div>

  <ul class="nav-list" id="main-menu" role="menubar">
    <li class="mobile-close-item" role="none">
      <button class="mobile-close-btn" id="mobile-close" aria-label="Cerrar menú">
        <span class="mobile-close-icon">✕</span> Cerrar menú
      </button>
    </li>

    <li class="dropdown" role="none">
      <button class="nav-btn" aria-haspopup="true" aria-expanded="false">
        Códigos <i class="chevron" aria-hidden="true">▾</i>
      </button>
      <ul class="submenu" role="menu">
        {codigos.map(({ id, label }) => (
          <li role="none"><a href={`/codigos/${id}`} role="menuitem">{label}</a></li>
        ))}
      </ul>
    </li>

    <li class="dropdown" role="none">
      <button class="nav-btn" aria-haspopup="true" aria-expanded="false">
        Escalas <i class="chevron" aria-hidden="true">▾</i>
      </button>
      <ul class="submenu" role="menu">
        {escalas.map(({ id, label }) => (
          <li role="none"><a href={`/escalas/${id}`} role="menuitem">{label}</a></li>
        ))}
      </ul>
    </li>

    <li role="none"><a href="/farmacos" role="menuitem">Fármacos</a></li>
    <li role="none"><a href="/ventilacion" role="menuitem">Ventilación</a></li>
    <li role="none"><a href="/triaje" role="menuitem">Triaje</a></li>
    <li role="none"><a href="/bibliografia" role="menuitem">Bibliografía</a></li>
  </ul>
</nav>

<script>
  type CleanupFn = () => void;
  let cleanups: CleanupFn[] = [];

  function teardown() {
    cleanups.forEach(fn => fn());
    cleanups = [];
  }

  function initNav() {
    teardown();

    const dropdowns = Array.from(document.querySelectorAll<HTMLElement>('.dropdown'));
    const hamburger   = document.getElementById('hamburger');
    const navList     = document.getElementById('main-menu');
    const overlay     = document.getElementById('nav-overlay');
    const mobileClose = document.getElementById('mobile-close');

    // ── Dropdown (desktop click-based) ──────────────────────────────
    function closeAllDropdowns() {
      dropdowns.forEach(d => {
        d.classList.remove('open');
        d.querySelector<HTMLElement>('[aria-expanded]')?.setAttribute('aria-expanded', 'false');
      });
    }

    dropdowns.forEach(dropdown => {
      const btn = dropdown.querySelector<HTMLButtonElement>('.nav-btn');
      if (!btn) return;

      const handleBtnClick = (e: Event) => {
        e.stopPropagation();
        const isOpen = dropdown.classList.contains('open');
        closeAllDropdowns();
        if (!isOpen) {
          dropdown.classList.add('open');
          btn.setAttribute('aria-expanded', 'true');
        }
      };

      btn.addEventListener('click', handleBtnClick);
      cleanups.push(() => btn.removeEventListener('click', handleBtnClick));
    });

    // Close on outside click
    const docClick = () => closeAllDropdowns();
    document.addEventListener('click', docClick);
    cleanups.push(() => document.removeEventListener('click', docClick));

    // Close on Escape
    const docKeydown = (e: KeyboardEvent) => {
      if (e.key === 'Escape') {
        closeAllDropdowns();
        closeMobileMenu();
      }
    };
    document.addEventListener('keydown', docKeydown);
    cleanups.push(() => document.removeEventListener('keydown', docKeydown));

    // ── Mobile menu ──────────────────────────────────────────────────
    function openMobileMenu() {
      navList?.classList.add('is-open');
      overlay?.classList.add('is-open');
      hamburger?.classList.add('is-open');
      hamburger?.setAttribute('aria-expanded', 'true');
      overlay?.removeAttribute('aria-hidden');
    }

    function closeMobileMenu() {
      navList?.classList.remove('is-open');
      overlay?.classList.remove('is-open');
      hamburger?.classList.remove('is-open');
      hamburger?.setAttribute('aria-expanded', 'false');
      overlay?.setAttribute('aria-hidden', 'true');
    }

    const toggleMobile = () =>
      navList?.classList.contains('is-open') ? closeMobileMenu() : openMobileMenu();

    hamburger?.addEventListener('click', toggleMobile);
    cleanups.push(() => hamburger?.removeEventListener('click', toggleMobile));

    overlay?.addEventListener('click', closeMobileMenu);
    cleanups.push(() => overlay?.removeEventListener('click', closeMobileMenu));

    mobileClose?.addEventListener('click', closeMobileMenu);
    cleanups.push(() => mobileClose?.removeEventListener('click', closeMobileMenu));

    // Close sidebar when a nav link is clicked (mobile)
    navList?.querySelectorAll('a').forEach(link => {
      const handler = () => closeMobileMenu();
      link.addEventListener('click', handler);
      cleanups.push(() => link.removeEventListener('click', handler));
    });
  }

  // Runs on initial load and after every Astro page transition
  document.addEventListener('astro:page-load', initNav);
</script>
