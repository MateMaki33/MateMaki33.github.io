---
import quemadosData from "../collections/quemados.json";
import { Image } from "astro:assets";
import myImage from "../assets/wallace.png";
import ParcklandComponent from "./calculators/ParcklandComponent.vue";
import SuperficieQuemadaPediatricaComponent from "./calculators/SuperficieQuemadaPediatricaComponent.vue";
import CriteriosGravedadQuemadurasComponent from "./calculators/CriteriosGravedadQuemadurasComponent.vue";

const data = quemadosData;
---

<div class="container">
  <header class="page-head">
    <span class="eyebrow">Madrid 112 · CAM</span>
    <h1>Quemados</h1>
    <div class="page-divider"></div>
  </header>

  <!-- ═══ EVALUACIÓN ═══ -->
  <section class="section">
    <div class="section-head">
      <span class="eyebrow">Evaluación</span>
      <h2>Anamnesis &amp; criterios</h2>
    </div>
    <div class="btn-grid">
      <button class="btn" onclick="modal_hospitales.showModal()">Hospitales</button>
      <button class="btn" onclick="modal_anamnesis.showModal()">Anamnesis</button>
      <button class="btn" onclick="modal_criterios.showModal()">Criterios de ingreso UGQ</button>
      <button class="btn" onclick="modal_otros_criterios.showModal()">Otros criterios ingreso</button>
      <button class="btn" onclick="modal_formula.showModal()">Fórmula de Parkland</button>
      <CriteriosGravedadQuemadurasComponent client:load label="Criterios de Gravedad" />
    </div>
  </section>

  <!-- ═══ ADULTO · SUPERFICIE Y FLUIDOS ═══ -->
  <section class="section">
    <div class="section-head">
      <span class="eyebrow">Reanimación · Adulto</span>
      <h2>Superficie quemada &amp; fluidoterapia</h2>
    </div>

    <div class="tools-row">
      <figure class="ref-figure">
        <Image
          src={myImage}
          alt="Regla de los 9 de Wallace"
          width="300"
          height="400"
        />
        <figcaption>Regla de los 9 · Wallace</figcaption>
      </figure>

      <div class="tools-calcs">
        <ParcklandComponent client:load></ParcklandComponent>
      </div>
    </div>
  </section>

  <!-- ═══ PEDIÁTRICO ═══ -->
  <section class="section panel ped-panel">
    <div class="section-head">
      <span class="eyebrow">
        <span class="ped-badge">PED</span> Población pediátrica
      </span>
      <h2>Quemaduras en el niño</h2>
      <p class="section-note">
        La quemadura pediátrica es un tipo de trauma. Valora también el
        <a href="/codigos/trauma">trauma pediátrico</a> (ITP, código PPT, constantes vitales y SRI).
      </p>
    </div>

    <div class="btn-grid">
      <SuperficieQuemadaPediatricaComponent client:load></SuperficieQuemadaPediatricaComponent>
      <CriteriosGravedadQuemadurasComponent client:load label="Criterios de Gravedad" />
    </div>
  </section>
</div>

<style>
  /* Pediatric module — distinct amber-accented panel (mirrors Trauma) */
  .ped-panel {
    --accent: var(--neon-orange);
    gap: 1.5rem;
    border-color: rgba(245, 158, 11, 0.28);
    background:
      linear-gradient(180deg, rgba(245, 158, 11, 0.05), transparent 55%),
      var(--color-card-bg);
  }
  .ped-badge {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    color: #1a1206;
    background: var(--neon-orange);
    padding: 0.1rem 0.4rem;
    border-radius: 4px;
    margin-right: 0.35rem;
    box-shadow: 0 0 16px rgba(245, 158, 11, 0.4);
  }
  .ped-panel .section-note a {
    color: var(--neon-orange);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .tools-row {
    display: grid;
    grid-template-columns: minmax(220px, 320px) 1fr;
    gap: 1.25rem;
    align-items: start;
    width: 100%;
  }

  .ref-figure {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 0.85rem;
    background: var(--color-card-bg);
    border: 1px solid var(--color-card-border);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
  }
  .ref-figure :global(img) {
    width: 100%;
    height: auto;
    border-radius: 8px;
    display: block;
  }
  .ref-figure figcaption {
    font-family: var(--font-display);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-subtitle);
    text-align: center;
  }

  .tools-calcs {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  /* Stretch the calculator trigger buttons to fill the column */
  .tools-calcs :global(.calc-wrapper),
  .tools-calcs :global(.grid) { width: 100%; }
  .tools-calcs :global(.btn-glow) { width: 100%; }

  @media (max-width: 680px) {
    .tools-row { grid-template-columns: 1fr; }
    .ref-figure { max-width: 320px; margin-inline: auto; }
  }
</style>

<dialog id="modal_hospitales">
  <h2>Hospitales</h2>
  <ul>
    {data.QUEMADOS.Hospitales.map((hospital) => <li>{hospital}</li>)}
  </ul>
  <form method="dialog">
    <button class="btn btn-close">Cerrar</button>
  </form>
</dialog>

<dialog id="modal_anamnesis">
  <h2>Anamnesis</h2>
  <h3>Aspectos a evaluar</h3>
  <ul>
    {
      data.QUEMADOS.Anamnesis.Aspectos_a_evaluar.map((aspecto) => (
        <li>{aspecto}</li>
      ))
    }
  </ul>
  <h3>Agente causal</h3>
  <ul>
    {data.QUEMADOS.Anamnesis.Agente_causal.map((agente) => <li>{agente}</li>)}
  </ul>
  <form method="dialog">
    <button class="btn btn-close">Cerrar</button>
  </form>
</dialog>

<dialog id="modal_criterios">
  <h2>Criterios de ingreso unidad de QUEMADOS</h2>
  <ul>
    {
      data.QUEMADOS.Criterios_de_ingreso_unidad_de_QUEMADOS.map((criterio) => (
        <li>{criterio}</li>
      ))
    }
  </ul>
  <form method="dialog">
    <button class="btn btn-close">Cerrar</button>
  </form>
</dialog>

<dialog id="modal_otros_criterios">
  <h2>Otros criterios de ingreso</h2>
  <ul>
    {
      data.QUEMADOS.Otros_criterios_de_ingreso.map((criterio) => (
        <li>{criterio}</li>
      ))
    }
  </ul>
  <form method="dialog">
    <button class="btn btn-close">Cerrar</button>
  </form>
</dialog>

<dialog id="modal_formula">
  <h2>Fórmula de Parkland</h2>
  <p style="color: var(--neon-glow);">
    {data.QUEMADOS.Formula_de_Parkland.Formula}
  </p>
  <h3>Administración</h3>
  <ul>
    {
      data.QUEMADOS.Formula_de_Parkland.Administracion.map((item) => (
        <li>{item}</li>
      ))
    }
  </ul>
  <form method="dialog">
    <button class="btn btn-close">Cerrar</button>
  </form>
</dialog>
