---
import ecmoData from "../collections/ecmo_rcp.json";
const data = ecmoData;
---

<style scoped>
  
  .card-madrid-direct{
    display: flex;
    flex-direction: row;
    max-height: 200px;
  }
  .scale{
    min-width: 70%;
  }
  .scale-btn{
    display: grid;
    inset: 0;
    place-content: center;
    width: 30%;
  }
  .pcr-link{
    width: 100%;
    gap: 0.6rem;
    border-color: rgba(239, 68, 68, 0.5);
    color: #fca5a5;
    background: rgba(239, 68, 68, 0.08);
  }
  .pcr-link:hover{
    background: rgba(239, 68, 68, 0.18);
    border-color: #ef4444;
    color: #fff;
  }
</style>

<div class="container">
  <h1>ECMO-RCP</h1>

  <a href="/pcr" class="btn pcr-link">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="18" height="18">
      <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
    </svg>
    Cronómetro de PCR · tiempo y fármacos
  </a>

  <div class="grid">
    <button class="btn" onclick="modal_definiciones.showModal(); modal_definiciones.scrollTop = 0;">Definiciones</button>
    <button class="btn" onclick="modal_inclusion.showModal(); modal_inclusion.scrollTop = 0;">Criterios de inclusión</button>
    <button class="btn" onclick="modal_contras.showModal(); modal_contras.scrollTop = 0;">Contraindicaciones absolutas</button>
    <button class="btn" onclick="modal_activacion.showModal(); modal_activacion.scrollTop = 0;">Activación del procedimiento</button>
    <button class="btn" onclick="modal_traslado.showModal(); modal_traslado.scrollTop = 0;">Traslado</button>
    <button class="btn" onclick="modal_transferencia.showModal(); modal_transferencia.scrollTop = 0;">Transferencia</button>
  </div>

</div>
</div>

<dialog id="modal_definiciones">
  <h2>Definiciones</h2>
  <ul>
    {data.secciones[0].puntos.map(c => (
      <li>{c}</li>
    ))}
  </ul>
  <form method="dialog"><button class="btn btn-close">Cerrar</button></form>
</dialog>

<dialog id="modal_inclusion">
  <h2>Criterios de inclusión</h2>
  <ul>
    {data.secciones[1].puntos.map(item => (
      <li>{item}</li>
    ))}
  </ul>
  <form method="dialog"><button class="btn btn-close">Cerrar</button></form>
</dialog>

<dialog id="modal_contras">
  <h2>Contraindicaciones absolutas</h2>
  <ul>
    {data.secciones[2].puntos.map(item => (
      <li>{item}</li>
    ))}
  </ul>
  <form method="dialog"><button class="btn btn-close">Cerrar</button></form>
</dialog>

<dialog id="modal_activacion">
  <h2>Activación</h2>
   <ul>
  {data.secciones[3].puntos.map(item => (
      <li>{item}</li>
    ))}
    </ul>
  
  <form method="dialog"><button class="btn btn-close">Cerrar</button></form>
</dialog>

<dialog id="modal_traslado">
  <h2>Traslado</h2>
  <ul>
    {data.secciones[4].puntos.map(item => (
      <li>{item}</li>
    ))}
  </ul>
  <form method="dialog"><button class="btn btn-close">Cerrar</button></form>
</dialog>

<dialog id="modal_transferencia">
  <h2>Transferencia</h2>
  <ul>
    {data.secciones[5].puntos.map(item => (
      <li>{item}</li>
    ))}
  </ul>
  <form method="dialog"><button class="btn btn-close">Cerrar</button></form>
; modal_special.scrollTop = 0;</dialog>


</div>
