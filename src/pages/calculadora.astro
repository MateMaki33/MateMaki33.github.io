---
import Layout from '../layouts/Layout.astro';
import CalculadoraPanel from '../components/calculadora/CalculadoraPanel.vue';
---

<Layout>
  <CalculadoraPanel client:load />
</Layout>

<!-- Full-screen tool: suppress the global footer so the page is exactly one
     viewport tall (no scrollbar). Only applies to this route's bundle. -->
<style is:global>
  @media (min-width: 981px) {
    .footer { display: none; }
    html, body { overflow: hidden; }
  }
</style>
